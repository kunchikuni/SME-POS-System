APP_NAME=Wivae
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://wivae.test

# Root domain for tenant subdomains. Dev uses wivae.test (add to /etc/hosts,
# plus a wildcard *.wivae.test entry). Production: set to your real domain.
APP_TENANT_DOMAIN=wivae.test

# Session cookie must be scoped to the root domain so it covers subdomains.
SESSION_DRIVER=redis
SESSION_DOMAIN=.wivae.test

# --- Supabase Postgres -------------------------------------------------------
# Use the SESSION pooler (port 5432) for Laravel, OR the transaction pooler
# (6543) with emulated prepares. The transaction pooler breaks named prepared
# statements, which Laravel uses by default — this bites once, in staging, at
# the worst time. Setting the session pooler avoids it entirely.
DB_CONNECTION=pgsql
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=

# If you must use the transaction pooler (6543), also set:
# DB_URL="pgsql://...:6543/postgres?options=--prepared_statements=false"

# --- Redis / Horizon ---------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
QUEUE_CONNECTION=redis

# --- Brand (overrides config/brand.php defaults) -----------------------------
BRAND_NAME=Wivae
BRAND_TRIAL_DAYS=7

# --- Supabase Storage (product images, receipts, white-label assets) ---------
# Server-side only. Never ship the anon key to any browser.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Paynow (subscription billing — docs §9.1) --------------------------------
# Get these from the Paynow merchant portal: https://www.paynow.co.zw
# Leave blank to disable the Billing tab gracefully (PaynowService::isAvailable
# returns false and shows a "Payments isn't available right now" message).
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
