{
  "name": "wivae",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint resources/js --ext .ts,.tsx",
    "pos:dev": "vite --config pos/vite.config.ts",
    "pos:build": "tsc -p pos/tsconfig.json && vite build --config pos/vite.config.ts",
    "pos:check": "tsc -p pos/tsconfig.json",
    "pos:test": "vitest run --config pos/vitest.config.ts",
    "pos:test:watch": "vitest --config pos/vitest.config.ts",
    "build:all": "npm run build && npm run pos:build",
    "pos:check:test": "tsc -p pos/tsconfig.test.json"
  },
  "dependencies": {
    "@inertiajs/react": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "jsbarcode": "^3.11.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-bluetooth": "^0.0.20",
    "@vitejs/plugin-react": "^4.3.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "laravel-vite-plugin": "^1.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "@types/jsbarcode": "^3.11.4"
  }
}
